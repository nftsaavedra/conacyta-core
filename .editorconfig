# EditorConfig helps maintain consistent coding styles across editors.
# https://editorconfig.org
# Reglas sincronizadas con wp-content/themes/conacyta/.editorconfig

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = false
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.{html,htm,xml,svg}]
indent_style = tab

[*.{css,scss,sass,less}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.php]
indent_size = 4

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
